<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fond dégradé radial -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splash_bg" />

    <!-- Contenu centré vertical -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="48dp">

        <!-- WISE SMART CHURCH (ligne 1) -->
        <TextView
            android:id="@+id/splash_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WISE SMART CHURCH"
            android:textSize="42sp"
            android:textColor="#D97706"
            android:letterSpacing="0.18"
            android:layout_gravity="center_horizontal"
            android:alpha="0" />

        <!-- SYSTEM -->
        <TextView
            android:id="@+id/splash_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.35"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:alpha="0" />

        <!-- Séparateur doré -->
        <View
            android:id="@+id/splash_divider"
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:background="#D97706"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="28dp"
            android:alpha="0" />

        <!-- "by" -->
        <TextView
            android:id="@+id/splash_by"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            android:letterSpacing="0.08"
            android:layout_gravity="center_horizontal"
            android:alpha="0" />

        <!-- Prophète Josias & Wise Design -->
        <TextView
            android:id="@+id/splash_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prophète Josias &amp; Wise Design"
            android:textSize="18sp"
            android:textColor="#F3F4F6"
            android:letterSpacing="0.06"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:alpha="0" />

        <!-- WhatsApp -->
        <TextView
            android:id="@+id/splash_contact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WhatsApp  +240 555 445 514"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:letterSpacing="0.05"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:alpha="0" />

    </LinearLayout>
</FrameLayout>
